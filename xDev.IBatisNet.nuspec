<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>xDev.IBatisNet</id>
    <version>1.6.2-xdev.9</version>
    <title>xDev.IBatisNet</title>
    <authors>tdduydev; Apache iBATIS.NET contributors</authors>
    <owners>tdduydev</owners>
    <license type="expression">Apache-2.0</license>
    <projectUrl>https://github.com/tdduydev/xDev.IBatisNet</projectUrl>
    <repository type="git" url="https://github.com/tdduydev/xDev.IBatisNet" />
    <readme>README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Compatibility-first xDev-maintained iBATIS.NET package for legacy .NET applications. The package keeps IBatisNet assembly names for existing applications and adds .NET 10 assets.</description>
    <releaseNotes>Add .NET Framework 4.0/4.5.2/4.7.2 package assets for legacy application compatibility while keeping the strong-named IBatisNet assembly identity and net10.0 assets.</releaseNotes>
    <copyright>Copyright 2007 The Apache Software Foundation and contributors; modifications copyright tdduydev.</copyright>
    <tags>ibatis ibatisnet datamapper xdev legacy sqlmap</tags>
    <dependencies>
      <group targetFramework=".NETFramework4.0">
        <dependency id="Castle.Core" version="3.1.0" />
      </group>
      <group targetFramework=".NETFramework4.5.2">
        <dependency id="Castle.Core" version="3.1.0" />
      </group>
      <group targetFramework=".NETFramework4.7.2">
        <dependency id="Castle.Core" version="3.1.0" />
      </group>
      <group targetFramework=".NETFramework4.8">
        <dependency id="Castle.Core" version="3.1.0" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="Castle.Core" version="5.2.1" />
        <dependency id="log4net" version="3.3.1" />
        <dependency id="System.Configuration.ConfigurationManager" version="10.0.8" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="README.md" target="" />
    <file src="IBatisNet.Common\bin\Release\IBatisNet.Common.dll" target="lib\net40" />
    <file src="IBatisNet.Common\bin\Release\IBatisNet.Common.xml" target="lib\net40" />
